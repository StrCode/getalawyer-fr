# API Configuration
NUXT_PUBLIC_API_URL=https://law-backend-production.up.railway.app
NUXT_PUBLIC_BETTER_AUTH_URL=https://law-backend-production.up.railway.app/api/auth

# Better Auth (Server-side)
BETTER_AUTH_SECRET=<random-256-bit-key>
BETTER_AUTH_URL=http://localhost:3000/api/auth

# Database
DATABASE_URL=<database-connection-string>

# NIN Verification (if applicable)
NIN_API_KEY=<nin-api-key>

# Cloudinary (if applicable)
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>
PORT="3000"
VITE_API_URL="https://law-backend-production.up.railway.app"
VITE_APP_URL="https://getalawyer-frontend.up.railway.app"
VITE_USE_MOCK_NIN="true"